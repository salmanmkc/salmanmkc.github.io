---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'Salman MKC', description = 'Projects and research by Salman MKC.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <style is:global>
      :root {
        --bg: #fafafa;
        --fg: #111;
        --muted: #6b6b6b;
        --line: #e6e6e6;
        --accent: #1a1a1a;
        --card: #ffffff;
        --radius: 10px;
        --maxw: 1100px;
        --font: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', Helvetica, Arial, sans-serif;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: var(--font);
        font-size: 16px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--fg); text-decoration: none; border-bottom: 1px solid var(--line); }
      a:hover { border-bottom-color: var(--fg); }
      img { max-width: 100%; display: block; }
    </style>
  </body>
</html>
