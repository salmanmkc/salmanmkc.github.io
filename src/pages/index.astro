---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---
<Base title="Salman Chishti — Projects">
  <main>
    <header class="hero">
      <h1>SalmanMKC</h1>
      <p class="lede">
        I build XR experiences, research interactive systems, and ship developer tools.
        A few recent projects:
      </p>
      <nav class="links">
        <a href="https://github.com/salmanmkc" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="salmanmkc-research@curiouslyconscientious.com">Email</a>
      </nav>
    </header>

    <section class="grid">
      {projects.map((p) => <ProjectCard project={p} />)}
    </section>

    <footer>
      <span>© {new Date().getFullYear()} SalmanMKC</span>
    </footer>
  </main>
</Base>

<style>
  main {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 80px 24px 60px;
  }
  .hero { margin-bottom: 48px; }
  h1 {
    font-size: clamp(34px, 5vw, 52px);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
    font-weight: 700;
  }
  .lede {
    font-size: 18px;
    color: #333;
    max-width: 640px;
    margin: 0 0 18px;
  }
  .links { display: flex; gap: 18px; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 22px;
  }
  footer {
    margin-top: 80px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 13px;
  }
  @media (max-width: 600px) {
    main { padding: 56px 18px 40px; }
  }
</style>
